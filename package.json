    "build:cli": "tsdown --config tsdown.cli.config.ts",
    "openapi:generate": "tsx --import ./scripts/ignore-css/register.mjs scripts/generate-openapi.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepack": "pnpm build:cli",
    "typecheck": "tsc --noEmit",
    "shadcn": "shadcn",
