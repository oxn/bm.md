{
  "name": "bmmd",
  "type": "module",
  "version": "0.1.0",
  "private": false,
  "packageManager": "pnpm@10.33.2",
  "description": "Markdown 排版 CLI，支持微信公众号、知乎、掘金与 HTML 输出。",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/miantiao-me/bm.md#readme",
  "repository": {
    "type": "git",
