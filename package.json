  },
  "bugs": {
    "url": "https://github.com/miantiao-me/bm.md/issues"
  },
  "keywords": [
    "markdown",
    "cli",
    "wechat",
    "zhihu",
    "juejin",
    "formatter"
  ],
  "bin": {
    "bmmd": "bin/bmmd.mjs"
  },
  "files": [
    "bin"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "dev": "vite dev --port 2663",
    "prebuild": "pnpm openapi:generate ",
